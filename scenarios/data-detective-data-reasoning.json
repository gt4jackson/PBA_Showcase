  "questions": [
    {
      "id": "q1",
      "type": "descriptive",
      "label": "Question 1 — Descriptive",
      "text": "Look at the overall revenue data. What's the general trend across quarters, and which region is performing best? Are there any quarters that stand out?",
      "hint": "Try sorting by revenue or comparing quarters across regions.",
      "scorer": {
        "key_concepts": [
          "q3 drop",
          "q3 dip",
          "q3 decline",
          "q3 lower",
          "west",
          "west region",
          "highest",
          "best performing",
          "strongest",
          "trend"
        ],
        "length_threshold": 40,
        "max_points": 30
      }
    },
    {
      "id": "q2",
      "type": "diagnostic",
      "label": "Question 2 — Diagnostic",
      "text": "Revenue dropped across all regions in Q3. What do you think caused it? Look at the other columns for clues. Is there a single explanation, or multiple factors?",
      "hint": "Compare Q3 to other quarters on dimensions beyond revenue. Look at sales reps, marketing spend, win rate, and churn.",
      "scorer": {
        "key_concepts": [
          "sales reps",
          "fewer reps",
          "headcount",
          "reps dropped",
          "marketing spend",
          "marketing cut",
          "reduced marketing",
          "budget cut",
          "win rate",
          "churn",
          "churn increased",
          "pipeline",
          "multiple factors",
          "combination"
        ],
        "length_threshold": 60,
        "max_points": 40
      }
    },
    {
      "id": "q3",
      "type": "prescriptive",
      "label": "Question 3 — Prescriptive",
      "text": "You're briefing the VP of Sales. Based on your analysis, what 2-3 actions would you recommend to prevent another Q3-style dip? Back up each recommendation with data from the table.",
      "hint": "Strong recommendations reference specific numbers and explain the mechanism (e.g., 'restoring rep headcount because NE lost 2 reps and revenue fell 26%').",
      "scorer": {
        "key_concepts": [
          "maintain headcount",
          "keep reps",
          "staffing",
          "restore reps",
          "marketing budget",
          "maintain marketing",
          "don't cut",
          "pipeline",
          "churn",
          "retention",
          "specific",
          "26%",
          "data",
          "evidence",
          "northeast",
          "west"
        ],
        "length_threshold": 80,
        "max_points": 30
      }
    }
  ],
  "anomalies": [
    {
      "id": "q3_rep_drop",
      "description": "Sales reps decreased in Q3 across NE (8→6), SE (6→5), and West (10→8) — likely a hiring freeze or layoff.",
      "severity": "primary"
    },
    {
      "id": "q3_marketing_cut",
      "description": "Marketing spend was cut 25-35% in Q3 across all regions.",
      "severity": "primary"
    },
    {
      "id": "q3_churn_spike",
      "description": "Churn rate spiked in Q3 (up 40-60% across regions), possibly due to reduced support.",
      "severity": "secondary"
    },
    {
      "id": "ne_avg_deal_q3",
      "description": "NE avg deal size actually INCREASED in Q3 ($30.5K vs ~$24K) — fewer but larger deals. Not all metrics went down.",
      "severity": "insight"
    },
    {
      "id": "midwest_resilience",
      "description": "Midwest was barely affected by Q3 — revenue only dropped ~2%. They had no rep change. Staffing stability may have buffered them.",
      "severity": "insight"
    }
  ],
  "coaching_tips": [
    "Always look at multiple columns before drawing conclusions. Revenue alone doesn't tell you why something happened.",
    "When you see a dip, ask 'what else changed at the same time?' — correlation across dimensions points to root causes.",
    "The Midwest barely moved in Q3 while others crashed. Comparing the stable case to the unstable cases is a powerful diagnostic strategy.",
    "Strong recommendations cite specific numbers. 'Maintain headcount' is good; 'NE lost 2 reps and revenue dropped 26%' is better.",
    "Don't assume the first pattern you see is the only one. Q3 had at least three concurrent factors: rep loss, marketing cuts, and churn spikes."
  ],
